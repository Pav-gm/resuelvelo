# Resuélvelo — Variables de entorno
# Copiar este archivo como .env.local y completar con los valores reales.
# Obtener en: https://supabase.com → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# URL pública de la app (sin slash final)
# Dev: http://localhost:3000
# Prod: https://resuelvelo.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
